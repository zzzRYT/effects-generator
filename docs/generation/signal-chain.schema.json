{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GP-150 Tone Patch",
  "description": "n8n 생성 노드의 Structured Output 스키마. docs/parser-contract.md의 signal_chain 계약을 미러링. 형식은 이 스키마가 강제하고, 시맨틱(type↔category 페어링·범위)은 web/lib/parser/validate.ts가 검증/수리 루프에서 강제한다.",
  "type": "object",
  "required": ["confidence", "genre", "variations"],
  "additionalProperties": false,
  "properties": {
    "confidence": { "type": "string", "description": "높음 | 보통 | 낮음 (+ 근거)" },
    "genre": { "type": "string", "description": "장르/톤 한 줄" },
    "variations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/variation" }
    }
  },
  "$defs": {
    "variation": {
      "type": "object",
      "required": ["label", "signal_chain"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "description": "변주 이름 (예: 정석 JCM800)" },
        "signal_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/block" }
        },
        "guitar": { "$ref": "#/$defs/guitar" },
        "switching": {
          "type": "object",
          "description": "풋스위치 → 동작 설명",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "block": {
      "type": "object",
      "required": ["type", "model", "enabled", "knobs"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "description": "GP-150 12모듈 슬롯",
          "enum": ["NR", "PRE", "WAH", "DST", "NS", "AMP", "CAB", "EQ", "MOD", "DLY", "RVB", "VOL"]
        },
        "category": {
          "description": "PRE: COMP·BOOST·FILTER·PITCH / DST: OD·DST·FUZZ. 그 외 모듈은 생략.",
          "enum": ["COMP", "BOOST", "FILTER", "PITCH", "OD", "DST", "FUZZ"]
        },
        "model": { "type": "string", "description": "그라운딩 목록의 GP-150 모델명 그대로" },
        "base_gear": { "type": "string", "description": "원본 실기 (예: Marshall JCM800)" },
        "enabled": { "type": "boolean" },
        "footswitch": { "enum": ["A", "B"] },
        "knobs": {
          "type": "array",
          "description": "빈 배열 허용 (예: IR-only CAB)",
          "items": { "$ref": "#/$defs/knob" }
        }
      }
    },
    "knob": {
      "type": "object",
      "required": ["name", "value"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "number" },
        "unit": {
          "description": "없으면 0–10/0–100 스케일 노브",
          "enum": ["ms", "s", "%", "Hz", "kHz"]
        }
      }
    },
    "guitar": {
      "type": "object",
      "description": "기타 본체 세팅 (Cort G250 HSS). 모든 키 선택.",
      "additionalProperties": false,
      "properties": {
        "selector": { "type": "integer", "minimum": 1, "maximum": 5, "description": "5-way 셀렉터 위치" },
        "volume": { "type": "number", "minimum": 0, "maximum": 10 },
        "tone": { "type": "number", "minimum": 0, "maximum": 10 },
        "coilSplit": { "type": "boolean" },
        "note": { "type": "string", "description": "섹션 변화·대안 메모" }
      }
    }
  }
}
