# 곡 제보 폼(request-form) — Web3Forms 폼-투-이메일. 백엔드 0.
# https://web3forms.com 에서 무료 access key 발급(받을 Gmail 주소 연결) 후 web/.env.local 에 복사.
# NEXT_PUBLIC_ 접두사라 빌드 타임에 클라이언트로 인라인된다(설계상 공개 라우팅 키 — 자격증명 아님).
# 미설정으로 프로덕션 빌드하면 fail-fast 한다(web/lib/requestEnv.ts).
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key

# (선택, 추후) 사이트 도메인 — no-JS 제출의 브랜디드 redirect(/request/sent)에 사용.
# 미설정이면 redirect 를 생략하고 Web3Forms 기본 성공페이지로 폴백한다.
# NEXT_PUBLIC_SITE_URL=https://your-domain.example

# 동적 카탈로그(피벗 Phase 3) — Supabase. anon 은 브라우저 읽기(RLS 공개읽기), service 는 서버 전용(쓰기/job).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 캐논 생성 LLM(서버 전용 — 파이프라인 lib/pipeline/. 투영은 AI 없음). OpenAI 호환 seam.
# provider=gemini(기본, 검색 그라운딩 내장) | ollama(로컬). 미설정이면 생성 호출 시 fail-fast.
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
# (선택) 모델·베이스URL 오버라이드. 기본 gemini-2.5-flash / Google OpenAI 호환 엔드포인트.
# LLM_MODEL=gemini-2.5-flash
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# ollama 사용 시: LLM_PROVIDER=ollama, LLM_BASE_URL=http://localhost:11434/v1, LLM_MODEL=llama3.1
